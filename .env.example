# Local settings for `make`. Copy to .env and fill in.
# .env is gitignored — safe for secrets. Do NOT quote values (Make reads this
# file as Makefile syntax, so `KEY="v"` becomes literally `"v"`).

# --- Required for `make init` / `plan` / `apply` -------------------------

# GCS bucket holding Terraform state. Created by `make bootstrap` — the
# script prints the exact name (format: ${PROJECT_ID}-tf-state-wad-demo).
TF_STATE_BUCKET=

# GCP project hosting the GKE cluster.
TF_VAR_project_id=

# Dash0 ingest token used by the operator's collectors.
TF_VAR_dash0_auth_token=

# Dash0 management API token used by the dash0 Terraform provider
# (needs write permissions on check rules, dashboards, etc.).
TF_VAR_dash0_api_token=

# --- Optional -----------------------------------------------------------

# TF_STATE_PREFIX=wad-demo/gke
# TF_VAR_region=europe-west1
# TF=tofu                     # use OpenTofu if local terraform is < 1.6

# --- For `make bootstrap` (one-time GCP setup) --------------------------

# PROJECT_ID=
# GITHUB_REPO=owner/repo
# REGION=europe-west1
